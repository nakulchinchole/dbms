Problem Statement:  
In a Customer Order Management System, data is stored in multiple tables such as 
Customers and Orders. To generate useful reports such as customer orders, pending 
orders, or customers without orders, it is necessary to combine data from these tables. 
SQL join operations are used to retrieve this information efficiently. 


-- STEP 1: Create & Use Database
CREATE DATABASE IF NOT EXISTS CompanyDB;
USE CompanyDB;

-- STEP 2: Clean Tables
DROP TABLE IF EXISTS Orders;
DROP TABLE IF EXISTS Customers;

-- STEP 3: Create Tables
CREATE TABLE Customers (
CustomerID INT PRIMARY KEY,
CustomerName VARCHAR(50),
City VARCHAR(50)
);

CREATE TABLE Orders (
OrderID INT PRIMARY KEY,
CustomerID INT,
Product VARCHAR(50),
Amount INT
);

-- STEP 4: Insert Data
INSERT INTO Customers VALUES
(1, 'Rahul', 'Pune'),
(2, 'Sneha', 'Mumbai'),
(3, 'Amit', 'Delhi'),
(4, 'Priya', 'Chennai');

INSERT INTO Orders VALUES
(101, 1, 'Laptop', 60000),
(102, 1, 'Mouse', 500),
(103, 2, 'Mobile', 20000),
(104, 5, 'Tablet', 15000);

-- STEP 5: Verify Data
SELECT * FROM Customers;
SELECT * FROM Orders;

-- =========================
-- INNER JOIN
-- =========================

SELECT Customers.CustomerID,
Customers.CustomerName,
Orders.OrderID,
Orders.Product,
Orders.Amount
FROM Customers
INNER JOIN Orders
ON Customers.CustomerID = Orders.CustomerID;

-- =========================
-- LEFT JOIN
-- =========================

SELECT Customers.CustomerID,
Customers.CustomerName,
Orders.OrderID,
Orders.Product
FROM Customers
LEFT JOIN Orders
ON Customers.CustomerID = Orders.CustomerID;

-- =========================
-- RIGHT JOIN
-- =========================

SELECT Customers.CustomerName,
Orders.OrderID,
Orders.Product
FROM Customers
RIGHT JOIN Orders
ON Customers.CustomerID = Orders.CustomerID;

-- =========================
-- FULL OUTER JOIN (MySQL Trick)
-- =========================

SELECT Customers.CustomerName,
Orders.OrderID,
Orders.Product
FROM Customers
LEFT JOIN Orders
ON Customers.CustomerID = Orders.CustomerID

UNION

SELECT Customers.CustomerName,
Orders.OrderID,
Orders.Product
FROM Customers
RIGHT JOIN Orders
ON Customers.CustomerID = Orders.CustomerID;































