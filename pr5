Step1:Create table Sales
CREATE TABLE sales (
 sale_id NUMBER PRIMARY KEY,
 product_name VARCHAR2(100),
 quantity NUMBER,
 price NUMBER,
 sale_date DATE
);

Step2 : retrieve tables
select *from sales

Step3:Create Procedure
CREATE OR REPLACE PROCEDURE add_sale (
 p_sale_id IN NUMBER,
 p_product_name IN VARCHAR2,
 p_quantity IN NUMBER,
 p_price IN NUMBER,
 p_sale_date IN DATE
)
AS
BEGIN
 INSERT INTO sales (sale_id, product_name, quantity, price, sale_date)
 VALUES (p_sale_id, p_product_name, p_quantity, p_price, p_sale_date);
 COMMIT;
END;
/

Step4:Insert Record
BEGIN
 add_sale(1, 'Laptop', 2, 50000, SYSDATE);
 add_sale(2, 'Mouse', 5, 500, SYSDATE);
END;
/

Step 5:Create Function
CREATE OR REPLACE FUNCTION get_total_sales
RETURN NUMBER
AS
 v_total NUMBER;
BEGIN
 SELECT SUM(quantity * price)
 INTO v_total
 FROM sales;
RETURN NVL(v_total, 0);
END;
/

Step6: Call Function
DECLARE
 total_sales NUMBER;
BEGIN
 total_sales := get_total_sales;
 DBMS_OUTPUT.PUT_LINE('Total Sales Amount: ' || total_sales);
END;
/
