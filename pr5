1. Create Table Sales: 
Querry: create table sales(sale_id number primary key,product_name 
varchar2(100),quantity number,price number,sale_date date); 


2. Create a stored procedure to add data to a table. 
Querry: create or replace procedure add_sale(p_sale_id in 
number,p_product_name in 
varchar2,p_quantity in number,p_price in number,p_sale_date in date) as begin insert into 
sales(sale_id,product_name,quantity,price,sale_date) 
values(p_sale_id,p_product_name,p_quantity,p_price,p_sale_date); commit; 
end; 
/


3.Insert Record: 
Querry: begin add_sale(1,'Laptop',2,50000,SYSDATE); add_sale(2,'Mouse',5,500,SYSDATE); 
end;  / 

4.Create function to calculate and return total sales. 
Querry:  create or replace function 
get_total_sales return number as v_total 
number; begin select sum(quantity*price) 
into v_total from sales; return  
nvl(v_total,0); end;  /  

5.Calling a function: 
Querry: 
declare total_sales number; begin 
total_sales:=get_total_sales; 
dbms_output.put_line('Total Sales Amount: '|| total_sales); 
end; 
/ 

