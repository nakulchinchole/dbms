DECLARE 
CURSOR emp_cursor IS  
SELECT emp_id, salary FROM Employees_New9 WHERE department = 'IT'; 
v_emp_id Employees_New9.emp_id%TYPE; 
v_salary Employees_New9.salary%TYPE; 
BEGIN 
OPEN emp_cursor; 
LOOP 
FETCH emp_cursor INTO v_emp_id, v_salary; 
EXIT WHEN emp_cursor%NOTFOUND; 
UPDATE Employees_New9 
SET salary = v_salary * 1.10 
WHERE emp_id = v_emp_id; 
END LOOP; 
CLOSE emp_cursor; 
COMMIT; 
END; 
/ 


