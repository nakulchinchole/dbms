PROBLEM STATEMENT:
Develop an Employee Management System with Triggers for Audit 
Logging and Cursors for Efficient Data Processing 

• SOLUTION: 
• Steps for Oracle Database: 
• In Terminal 
• Step1: sudo service oracle-xe configure 
• Step2: sudo service oracle-xe 
start In Firefox 
http://127.0.0.1:8080/apex/

1. Create Tables: 
• Employee Table 
Querry: CREATE TABLE Employees_New ( 
emp_id NUMBER PRIMARY KEY, 
emp_name VARCHAR2(100), 
department VARCHAR2(50), 
salary NUMBER 
); 

• Audit Table 
Querry: 
CREATE TABLE Employee_Audit_New ( 
audit_id NUMBER PRIMARY KEY, 
emp_id NUMBER, 
action VARCHAR2(10), 
old_salary NUMBER, 
new_salary NUMBER, 
action_date DATE 
);

2. CREATE SEQUENCE: 
Querry: 
CREATE SEQUENCE emp_audit_seq_new 
START WITH 1 
INCREMENT BY 1; 

3.CREATE TRIGGER:  
QUERRY: 
CREATE OR REPLACE TRIGGER emp_audit_trigger 
AFTER INSERT OR UPDATE OR DELETE ON Employees_New 
FOR EACH ROW 
BEGIN 
IF INSERTING THEN 
INSERT INTO Employee_Audit_New 
VALUES(emp_audit_seq_new.NEXTVAL, :NEW.emp_id, 'INSERT', NULL, :NEW.salary, SYSDATE); 
ELSIF UPDATING THEN 
INSERT INTO Employee_Audit_New 
VALUES(emp_audit_seq_new.NEXTVAL, :NEW.emp_id, 'UPDATE', :OLD.salary, :NEW.salary, 
SYSDATE); 
ELSIF DELETING THEN 
INSERT INTO Employee_Audit_New 
VALUES(emp_audit_seq_new.NEXTVAL, :OLD.emp_id, 'DELETE', :OLD.salary, NULL, SYSDATE); 
END IF; 
END; 
/

