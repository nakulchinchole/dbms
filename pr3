PART 1: Filtering Data Using WHERE 
Example 1: Find students above age 21 
SELECT * 
FROM Students 
WHERE age > 21; 

Example 2: Find courses taught by Dr. Sharma 
SELECT * 
FROM Courses
WHERE instructor =’Dr. Sharma’;


Example 3: Find students enrolled in Data Science 
SELECT s.name, c.course_name 
FROM Students s 
JOIN Courses c ON s.course_id = c.course_id 
WHERE c.course_name = ‘Data Science’;



PART 2: Sorting Using ORDER BY 
Example 1: Sort students alphabetically 
SELECT * 
FROM Students 
ORDER BY name ASC;


Example 2: Sort courses bhighy credits (est first) 
SELECT * 
FROM Courses 
ORDER BY credits DESC;

PART 3: Aggregation Using GROUP BY 
Example 1: Count number of students per course 
SELECT c.course_name, COUNT(s.student_id) AS student_count 
FROM Students s

JOIN Courses c ON s.course_id = c.course_id 
GROUP BY c.course_name; 

Example 2: Find average age of students 
SELECT AVG(age) AS average_age 
FROM Students;

Example 3: Average age per course 
SELECT c.course_name, AVG(s.age) AS avg_age 
FROM Students s 
JOIN Courses c ON s.course_id = c.course_id 
GROUP BY c.course_name;

PART 4: Nested Subqueries (Advanced Queries) 
Example 1: Find students enrolled in course with highest credits 
SELECT name 
FROM Students 
WHERE course_id = ( 
SELECT course_id 
FROM Courses 
ORDER BY credits DESC 
LIMIT 1 
);  


Example 2: Find students older than average age 
SELECT name, age 
FROM Students 
WHERE age &gt; ( 
SELECT AVG(age) 
FROM Students 
);


Example 3: Find course having maximum number of students 
SELECT course_name 
FROM Courses 
WHERE course_id = ( 
SELECT course_id 
FROM Students 
GROUP BY course_id 
ORDER BY COUNT(student_id) DESC 
LIMIT 1 
);









































