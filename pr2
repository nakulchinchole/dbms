Practical no: 2

Problem Statement  
A Student Course Management System contains multiple tables such as Students, Courses, 
and Enrollments. Retrieving detailed student and course information often requires 
complex joins, which can slow down queries.  


-- STEP 1: Create & Use Database
CREATE DATABASE IF NOT EXISTS UniversityDB;
USE UniversityDB;

-- STEP 2: Clean Previous Tables
DROP TABLE IF EXISTS Students;
DROP TABLE IF EXISTS Courses;

-- STEP 3: Create Tables
CREATE TABLE Courses (
    course_id INT PRIMARY KEY,
    course_name VARCHAR(50),
    credits INT,
    instructor VARCHAR(50)
);

CREATE TABLE Students (
    student_id INT PRIMARY KEY,
    name VARCHAR(50),
    age INT,
    course_id INT,
    FOREIGN KEY (course_id) REFERENCES Courses(course_id)
);

-- STEP 4: Insert Data
INSERT INTO Courses VALUES
(1, 'Database Systems', 4, 'Dr. Sharma'),
(2, 'Data Science', 3, 'Dr. Mehta'),
(3, 'Computer Networks', 4, 'Dr. Sharma');

INSERT INTO Students VALUES
(101, 'Amit', 20, 1),
(102, 'Priya', 22, 2),
(103, 'Rahul', 19, 1),
(104, 'Sneha', 21, 3),
(105, 'Kiran', 23, 2);

-- STEP 5: Create Views
CREATE VIEW StudentView AS
SELECT student_id, name, age
FROM Students;

CREATE VIEW StudentCourseReport AS
SELECT s.student_id, s.name, s.age, c.course_name, c.instructor
FROM Students s
JOIN Courses c ON s.course_id = c.course_id;

-- STEP 6: Use View
SELECT * FROM StudentCourseReport;

-- STEP 7: Update Using View
UPDATE StudentView
SET age = 24
WHERE student_id = 105;

-- STEP 8: Delete Using View
DELETE FROM StudentView
WHERE student_id = 103;

-- STEP 9: Verify Changes
SELECT * FROM Students;

-- STEP 10: Create Index
CREATE INDEX idx_course_id
ON Students(course_id);

CREATE INDEX idx_instructor
ON Courses(instructor);

-- STEP 11: Check Performance
EXPLAIN 
SELECT * FROM Students
WHERE course_id = 2;
